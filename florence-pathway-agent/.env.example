# Florence Pathway Agent — environment

# Optional. When set, the LLM-backed agents (document extraction, candidate-facing
# explanations, deficiency classification, QA narrative) use Claude. When unset,
# the app runs fully on the deterministic/heuristic provider — no key required.
ANTHROPIC_API_KEY=

# Model used when ANTHROPIC_API_KEY is present.
ANTHROPIC_MODEL=claude-opus-4-8

# API server port (Vite proxies /api here).
PORT=8787

# Optional webhook that receives FlorenceRN production-ledger milestone events.
# When unset, milestones are recorded locally and logged.
FLORENCE_LEDGER_WEBHOOK=

# Optional webhook for proactive candidate reminders (wire to your email/SMS/WhatsApp
# provider, e.g. Postmark/Twilio). When unset, reminders are computed and logged only.
FLORENCE_NOTIFY_WEBHOOK=
