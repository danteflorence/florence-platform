{
  "name": "florence-pathway-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AI-assisted administrative automation for the FlorenceRN nurse pathway: visa, NCLEX/ATT, licensure, endorsement, EB-3/Schedule A, CGFNS/VisaScreen. AI prepares & validates, human QA reviews, candidate signs.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "api": "node --experimental-sqlite --watch --import tsx server/index.ts",
    "web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "seed": "node --experimental-sqlite --import tsx scripts/seed.ts",
    "pathway-v1-smoke": "node --experimental-sqlite --import tsx scripts/pathway-v1-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
