# FlorenceRN single-VPS test stack — copy to `.env`, fill in, then:
#   docker compose up -d --build

# The domain you control and point at this server. All apps live under it as
# subdomains (id, academy, api.academy, live.academy, pathway, ats, pricing) so
# the SSO cookie can be shared. Point a wildcard under this example domain, or
# each subdomain, at the server's public IP.
BASE_DOMAIN=test.example.com

# Email for Let's Encrypt certificate registration.
ACME_EMAIL=you@example.com

# Google Workspace domain that staff sign in from (Google accounts). Independent
# of BASE_DOMAIN.
STAFF_DOMAIN=example.com

# Postgres password. Use a generated value from a secret manager.
PG_PASSWORD=__SET_IN_SECRET_MANAGER__

# STABLE across restarts — encrypts Core's signing keys at rest. Never change it
# once set or every signing key is orphaned. Generate: openssl rand -hex 32
FIELD_ENC_PASSPHRASE=__SET_IN_SECRET_MANAGER__

# Core demo M2M client secret + ATS connector-credential vault key. Generate each.
DEMO_CLIENT_SECRET=__LOCAL_DEV_ONLY__
ATS_CONNECT_VAULT_KEY=__SET_IN_SECRET_MANAGER__
WEBHOOK_SECRET=__SET_IN_SECRET_MANAGER__

# Google OAuth (optional for a test box — leave blank to use password sign-in).
# If set, add redirect URI https://id.${BASE_DOMAIN}/auth/google/callback in GCP.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Live classroom A/V (Agora) — create a project at console.agora.io, then set the
# App ID + a (primary) App Certificate. Blank → Academy live runs slides-only.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Cloud recording (optional) — enable Cloud Recording on the Agora project, make a
# RESTful Customer ID/Secret, and point at a storage bucket (vendor 1 = AWS S3;
# also GCS/Azure/OSS). Blank → the instructor Record button is hidden.
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
AGORA_REC_VENDOR=1
AGORA_REC_REGION=0
AGORA_REC_BUCKET=
AGORA_REC_ACCESS_KEY=
AGORA_REC_SECRET_KEY=
AGORA_REC_PREFIX=florence-academy
# Public/CDN base in front of the bucket so replays play back globally (e.g. a
# CloudFront/Cloudflare URL). Blank → recordings are listed but not playable.
AGORA_REC_PUBLIC_BASE=

# ElevenLabs — pre-recorded narration (rationales + lessons) + voice tutor.
# Blank → audio players + tutor button hidden (mock pipeline still runs offline).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
# From `npm run audio:dict` (clinical pronunciation):
ELEVENLABS_DICTIONARY_ID=
ELEVENLABS_DICTIONARY_VERSION_ID=
# From `npm run audio:tutor` (creates the agent) → enables the voice tutor:
ELEVENLABS_AGENT_ID=
# Optional CDN in front of the generated audio bucket; blank → API serves clips.
AUDIO_PUBLIC_BASE=

# Nurse Passport spine — per-app Core M2M client secrets so Academy/ATS/Pathway
# can emit journey events to Core. Blank → each app's emits are a silent no-op.
# After `docker compose up`, run once:  docker compose exec core npm run seed-app-clients
# then paste the printed secrets here and `docker compose up -d` to apply.
FLORENCE_ACADEMY_CLIENT_SECRET=
FLORENCE_ATS_CLIENT_SECRET=
FLORENCE_PATHWAY_CLIENT_SECRET=

# Optional integrations.
ANTHROPIC_API_KEY=
BLS_REGISTRATION_KEY=

# Workforce Economist pricing-api. Lives in the SEPARATE `labor-economics-agent`
# repo (not in this monorepo). Leave blank → ATS Demand Radar uses a standard
# fallback fee. To run it locally, check that repo out alongside this one and run
# `docker compose --profile pricing up`; in prod, set this to the hosted URL.
PRICING_API_URL=
