# FlorenceRN root environment template
#
# Copy only the variables needed by the workflow you are running. Secret values
# must come from an approved secret manager and must never be committed.

NODE_ENV=development

# Shared local hosts
PUBLIC_CORE_URL=http://id.lvh.me:8080
VITE_CORE_URL=http://id.lvh.me:8080

# Secret placeholders. Leave blank locally unless a command explicitly requires
# a generated development value.
FIELD_ENC_PASSPHRASE=
DEMO_CLIENT_SECRET=
ATS_CONNECT_VAULT_KEY=
ANTHROPIC_API_KEY=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
