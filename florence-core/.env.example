# ── FlorenceRN Core — environment ──────────────────────────────────────────
# Copy to .env for local dev. Nothing here is required to BOOT (Core generates
# ephemeral dev values and prints a warning), but Google login + Postgres need
# real values.

# Port the identity service listens on.
PORT=8080

# Public origin of Core (used to build the Google redirect URI + discovery doc).
#   local:  http://id.lvh.me:8080
#   prod:   https://id.example.com
PUBLIC_CORE_URL=http://id.lvh.me:8080

# Token contract. iss/aud are what every app verifies — keep stable across the fleet.
TOKEN_ISS=florence-auth
TOKEN_AUD=florence
# Short-lived access token (the fl_session cookie). Kept small on purpose; the
# refresh cookie slides the session silently, so 1h is comfortable.
HUMAN_SESSION_TTL_SEC=3600
# Long-lived rotating refresh token (the fl_refresh cookie). 30 days default.
REFRESH_TTL_SEC=2592000
M2M_TOKEN_TTL_SEC=900

# SSO cookie. The leading-dot domain is what makes one login work on every subdomain.
#   local:  .lvh.me   (with COOKIE_SECURE=0 because local is http)
#   prod:   .example.com
COOKIE_DOMAIN=.lvh.me
COOKIE_SECURE=0

# Staff domain → Google sign-in is restricted to these; first staff user becomes super_admin.
FLORENCE_ALLOWED_DOMAIN=example.com

# Hosts a post-login redirect may target (comma-separated suffixes). Prevents open redirects.
FLORENCE_REDIRECT_HOSTS=.example.com,.lvh.me,localhost

# Google OAuth 2.0 Web client (YOU provision in Google Cloud — see DEPLOY.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Defaults to ${PUBLIC_CORE_URL}/auth/google/callback when unset.
GOOGLE_REDIRECT_URI=

# Encrypts RSA signing private keys at rest. MUST be stable across deploys/restarts
# (a changed passphrase orphans every signing key). Set a long random value in prod.
FIELD_ENC_PASSPHRASE=

# Postgres. When unset, Core uses an in-memory store; set CORE_STATE_FILE to persist it locally.
DATABASE_URL=
CORE_STATE_FILE=data/core-dev.json

# Optional M2M demo client (client_credentials) so the fleet works out of the box.
DEMO_CLIENT_ID=florence-core-demo
DEMO_CLIENT_SECRET=
